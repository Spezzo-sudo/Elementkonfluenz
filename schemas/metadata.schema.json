{
  "title": "Elementkonfluenz Platform Metadata",
  "type": "object",
  "required": [
    "contract_version",
    "job_id",
    "platform",
    "title",
    "description",
    "hashtags",
    "requires_review"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "default": "0.1"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "youtube",
        "tiktok",
        "instagram",
        "x"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "hashtags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "thumbnail_text": {
      "type": "string"
    },
    "content_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "advisory_check": {
      "type": "object",
      "properties": {
        "flagged": {
          "type": "boolean"
        },
        "matched_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "requires_review": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
