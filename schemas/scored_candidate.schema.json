{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ValueRacer Scored Candidate",
  "type": "object",
  "required": ["topic_slug", "title", "video_type", "template", "assets", "final_score", "hard_blocked", "requires_review", "ready_to_publish"],
  "properties": {
    "topic_slug": {"type": "string"},
    "title": {"type": "string"},
    "video_type": {"type": "string"},
    "template": {"type": "string"},
    "assets": {"type": "array", "items": {"type": "string"}},
    "asset_labels": {"type": "array", "items": {"type": "string"}},
    "keywords": {"type": "array", "items": {"type": "string"}},
    "signal_id": {"type": "string"},
    "base_score": {"type": "integer"},
    "final_score": {"type": "integer"},
    "hard_blocked": {"type": "boolean"},
    "requires_review": {"const": true},
    "ready_to_publish": {"const": false}
  },
  "additionalProperties": true
}
